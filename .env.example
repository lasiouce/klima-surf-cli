# Copy to `.env` and fill in. `.env` is gitignored.
#
# No API keys are needed for forecast data: swell, wind, weather AND tides all
# come from Open-Meteo (free, keyless). Only the notification channels below
# need secrets.

# Telegram (Phase 4) — optional
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp (Meta WhatsApp Cloud API, Phase 4) — optional
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_RECIPIENT=
